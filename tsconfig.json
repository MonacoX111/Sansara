{
  "include": ["./src/**/*"],
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2016",
    "lib": ["dom", "dom.iterable", "es2016", "es2017"],
    "jsx": "react-jsx",
    "module": "esnext",
"moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  }
}